  .perm-icon{font-size:64px;filter:drop-shadow(0 0 8px #FFD700)}
  .perm-title{font-size:20px;letter-spacing:5px;color:#FFD700;text-align:center}
  .perm-desc{font-size:14px;line-height:2;border:rgba(255,255,255,0.5);text-align:center;max-width:380px;letter-spacing:1px}
  .perm-btn{padding:18px 52px;background:transparent;border:1px solid rgba(255,215,0,0.6);color:#FFD700;
    font-size:14px;letter-spacing:4px;cursor:pointer;border-radius:10px;
    transition:all 0.3s ease;-webkit-appearance:none;
    box-shadow:0 0 10px rgba(255,215,0,0.2)
  }
  .perm-btn:active{background:rgba(255,215,0,0.2)}
  /* 顶部状态栏 HUD */
  #hud{position:fixed;top:0;left:0;right:0;z-index:10;padding:env(safe-area-inset-top,16px) 24px 12px;
    display:flex;justify-content:space-between;align-items:flex-start;pointer-events:none;
    background:linear-gradient(to bottom,rgba(0,0,0,0.6),transparent)
  }
  .hud-l .t{font-size:14px;font-weight:700;letter-spacing:4px;color:#FFD700}
  .hud-l .s{font-size:11px;letter-spacing:2px;color:rgba(255,255,255,0.35);margin-top:4px}
  .hud-r{text-align:right}
  .stat{font-size:11px;letter-spacing:2px;color:rgba(255,255,255,0.4);margin-bottom:4px}
  .stat span{color:#36CFFB;font-weight:600}
  /* 摄像头预览窗口 */
  #camWrap{position:fixed;bottom:calc(env(safe-area-inset-bottom,0px) + 20px);right:20px;z-index:10;
    border:1px solid rgba(255,215,0,0.3);border-radius:14px;overflow:hidden;width:128px;height:96px;
    box-shadow:0 0 15px rgba(54,207,251,0.2)
  }
  #inputVideo{width:128px;height:96px;object-fit:cover;transform:scaleX(-1);opacity:0.85;display:block}
