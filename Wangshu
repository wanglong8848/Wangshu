  <div class="g-item"><span class="g-icon">✋</span><span class="g-text">张手 展开剑阵</span></div>
  <div class="g-item"><span class="g-icon">✊</span><span class="g-text">握拳 凝剑聚罡</span></div>
  <div class="g-item"><span class="g-icon">☝️</span><span class="g-text">单指 剑气穿刺</span></div>
  <div class="g-item"><span class="g-icon">🙌</span><span class="g-text">双手 剑阵轮转</span></div>
</div>

<script src="https://cdn.jsdelivr.net/npm/@mediapipe/camera_utils/camera_utils.js" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/@mediapipe/drawing_utils/drawing_utils.js" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/@mediapipe/hands/hands.js" crossorigin="anonymous"></script>
<script>
// ===================== 全局常量 - 大庚剑阵配色 & 配置 =====================
const SWORD_COLOR = {
  gold: '255, 215, 0',    // 鎏金主色
  cyan: '54, 207, 251',   // 青冥剑气
  fire: '255, 74, 44'     // 赤红剑罡
};
const MODE_CONFIG = {
  attract: { name: '布开剑阵', emoji: '✋', color: SWORD_COLOR.gold },
  repel: { name: '凝剑聚罡', emoji: '✊', color: SWORD_COLOR.fire },
  draw: { name: '剑气穿刺', emoji: '☝️', color: SWORD_COLOR.cyan },
  vortex: { name: '剑阵轮转', emoji: '🙌', color: '180, 140, 255' }
};
let W, H, frameN = 0;
const canvas = document.getElementById('mainCanvas');
const ctx = canvas.getContext('2d');
const oc = document.getElementById('overlayCanvas');
const octx = oc.getContext('2d');

// ===================== 音效模块【新增】=====================
let audioUnlocked = false;
let lastPlayMode = '';
const audioCoolDown = 600; // 音效冷却(ms)，防止重复刷屏
let lastAudioTime = 0;

// 音效资源：免费在线音效CDN，分别对应不同招式+背景音
const AUDIO_SRC = {
  bgm: "https://assets.mixkit.co/sfx/preview/mixkit-distant-thunder-rumble-1290.mp3",    // 剑阵底噪(循环)
  attract: "https://assets.mixkit.co/sfx/preview/mixkit-ethereal-wind-sweep-1182.mp3", // 布阵风声
  repel: "https://assets.mixkit.co/sfx/preview/mixkit-impact-thud-2577.mp3",           // 凝剑重击
  draw: "https://assets.mixkit.co/sfx/preview/mixkit-fast-swoosh-1347.mp3",            // 穿刺破空
  vortex: "https://assets.mixkit.co/sfx/preview/mixkit-whirlwind-wind-1315.mp3"         // 轮转旋风
};

// 音效实例
const audioPool = {
  bgm: new Audio(AUDIO_SRC.bgm),
  attract: new Audio(AUDIO_SRC.attract),
  repel: new Audio(AUDIO_SRC.repel),
  draw: new Audio(AUDIO_SRC.draw),
  vortex: new Audio(AUDIO_SRC.vortex)
};

// 音量统一配置
Object.values(audioPool).forEach(aud => {
  aud.volume = 0.25;
  aud.preload = "auto";
});
audioPool.bgm.loop = true; // 背景音循环

// 解锁音频（浏览器必须用户点击后才能播放）
function unlockAudio() {
  if(audioUnlocked) return;
  // 空播放解锁音频上下文
  const tempAud = new Audio();
  tempAud.play().catch(()=>{});
  audioUnlocked = true;
}

// 播放对应招式音效（带冷却）
function playModeAudio(mode) {
  if(!audioUnlocked) return;
  const now = Date.now();
  if(now - lastAudioTime < audioCoolDown) return;
  if(lastPlayMode === mode) return;

  lastAudioTime = now;
  lastPlayMode = mode;
  const aud = audioPool[mode];
  aud.currentTime = 0; // 从头播放
  aud.play().catch(e=>console.log("音效播放拦截"));
}

// 启动剑阵背景音
function startBGM() {
  if(!audioUnlocked) return;
  audioPool.bgm.currentTime = 0;
  audioPool.bgm.play().catch(()=>{});
}

// 停止所有音效
function stopAllAudio() {
  Object.values(audioPool).forEach(aud => {
    aud.pause();
    aud.currentTime = 0;
  });
}
// ==========================================================

// 防抖窗口缩放
let resizeTimer;
function resize() {
  W = canvas.width = window.innerWidth;
  H = canvas.height = window.innerHeight;
  oc.width = 128; oc.height = 96;
}
window.addEventListener('resize', () => {
  clearTimeout(resizeTimer);
  resizeTimer = setTimeout(resize, 100);
});
resize();

// ===================== 剑粒子类 - 重构为仙侠剑刃形态 =====================
class SwordParticle {
  constructor() {
    this.type = Math.floor(Math.random() * 3); // 0:短刃 1:剑丝 2:星剑
    this.angle = Math.random() * Math.PI * 2; // 剑体旋转角度
    this.rotSpeed = (Math.random() - 0.5) * 0.02; // 自转速度
    this.init();
  }
  init() {
    this.x = Math.random() * W;
    this.y = Math.random() * H;
    this.vx = (Math.random() - 0.5) * 1.5;
    this.vy = (Math.random() - 0.5) * 1.5;
    this.baseSize = 2 + Math.random() * 4;
    this.size = this.baseSize;
    this.life = Math.random();
    this.maxLife = 0.6 + Math.random() * 0.4;
    this.alpha = 0;
    this.energy = 0;
    this.trail = [];
    this.color = SWORD_COLOR.gold;
  }

  update(handPoints, mode) {
    // 剑影拖尾
    this.trail.push({ x: this.x, y: this.y });
    if (this.trail.length > 9) this.trail.shift();

    this.life += 0.0028;
    if (this.life > this.maxLife) { this.init(); return; }

    // 生命周期透明度
    const t = this.life / this.maxLife;
    this.alpha = t < 0.1 ? t / 0.1 : t > 0.8 ? (1 - t) / 0.2 : 1;
    this.energy *= 0.92;
    this.angle += this.rotSpeed; // 剑体自转

    // 手势力场计算（剑阵物理）
    for (const p of handPoints) {
      const dx = p.x - this.x;
      const dy = p.y - this.y;
      const dist = Math.hypot(dx, dy) || 0.001;
      const range = 240;
      if (dist < range) {
        const force = Math.pow((range - dist) / range, 2) * 4;
        this.energy = Math.max(this.energy, force / 4);
        this.color = MODE_CONFIG[mode].color;

        // 不同招式力场逻辑
        switch (mode) {
          case 'attract': // 布阵：向外铺展
            this.vx -= dx / dist * force * 0.16;
            this.vy -= dy / dist * force * 0.16;
            break;
          case 'repel': // 凝剑：向中心汇聚
            this.vx += dx / dist * force * 0.24;
            this.vy += dy / dist * force * 0.24;
            break;
          case 'draw': // 指剑：定向牵引穿刺
            this.vx += dx / dist * force * 0.08;
            this.vy += dy / dist * force * 0.08;
            break;
          case 'vortex': // 旋阵：环形旋转
            const rad = Math.atan2(dy, dx) + Math.PI / 2;
            this.vx += Math.cos(rad) * force * 0.13;
            this.vy += Math.sin(rad) * force * 0.13;
            break;
        }
      }
    }

    // 速度限制 & 随机扰动
    this.vx = this.vx * 0.97 + (Math.random() - 0.5) * 0.2;
    this.vy = this.vy * 0.97 + (Math.random() - 0.5) * 0.2;
    const spd = Math.hypot(this.vx, this.vy);
    if (spd > 8) {
      this.vx = this.vx / spd * 8;
      this.vy = this.vy / spd * 8;
    }

    // 边界循环
    this.x += this.vx;
    this.y += this.vy;
    if (this.x < -60) this.x = W + 60;
    if (this.x > W + 60) this.x = -60;
    if (this.y < -60) this.y = H + 60;
    if (this.y > H + 60) this.y = -60;

    this.size = this.baseSize + this.energy * 4;
  }

  // 绘制剑刃/剑丝（核心视觉）
  draw() {
    const [r, g, b] = this.color.split(',');
    const a = this.alpha;
    const energyA = this.alpha * this.energy;

    // 1. 剑拖尾流光
    if (this.trail.length > 3 && this.energy > 0.06) {
      ctx.beginPath();
      ctx.moveTo(this.trail[0].x, this.trail[0].y);
      for (let i = 1; i < this.trail.length; i++) {
        ctx.lineTo(this.trail[i].x, this.trail[i].y);
      }
      ctx.strokeStyle = `rgba(${r},${g},${b},${energyA * 0.2})`;
      ctx.lineWidth = this.size * 0.3;
      ctx.stroke();
    }

    // 2. 绘制不同形态剑体
    ctx.save();
    ctx.translate(this.x, this.y);
    ctx.rotate(this.angle);
    if (this.type === 0) {
      // 短剑刃
      ctx.beginPath();
      ctx.moveTo(-this.size * 2, 0);
      ctx.lineTo(this.size * 2, 0);
      ctx.strokeStyle = `rgba(${r},${g},${b},${a})`;
      ctx.lineWidth = this.size * 0.4;
      ctx.stroke();
    } else if (this.type === 1) {
      // 细长剑丝
      ctx.beginPath();
      ctx.moveTo(-this.size * 3, 0);
      ctx.lineTo(this.size * 3, 0);
      ctx.strokeStyle = `rgba(${r},${g},${b},${a * 0.8})`;
      ctx.lineWidth = this.size * 0.2;
      ctx.stroke();
    } else {
      // 星型剑点（带辉光）
      const glow = ctx.createRadialGradient(0, 0, 0, 0, 0, this.size * 3);
      glow.addColorStop(0, `rgba(${r},${g},${b},${a})`);
      glow.addColorStop(1, `rgba(${r},${g},${b},0)`);
      ctx.beginPath();
      ctx.arc(0, 0, this.size * 3, 0, Math.PI * 2);
      ctx.fillStyle = glow;
      ctx.fill();
    }
    ctx.restore();
  }
}

// ===================== 剑阵辅助特效：剑网、阵环、底纹 =====================
// 绘制剑网连线（粒子之间的光络）
function drawSwordNet(particles) {
  const linkDist = 80;
  ctx.lineCap = 'round';
  for (let i = 0; i < particles.length; i++) {
    const p1 = particles[i];
    if (p1.energy < 0.05) continue;
    for (let j = i + 1; j < particles.length; j++) {
      const p2 = particles[j];
      if (p2.energy < 0.05) continue;
      const dist = Math.hypot(p1.x - p2.x, p1.y - p2.y);
      if (dist < linkDist) {
        const alpha = (1 - dist / linkDist) * Math.min(p1.alpha, p2.alpha) * 0.3;
        ctx.beginPath();
        ctx.moveTo(p1.x, p1.y);
        ctx.lineTo(p2.x, p2.y);
        ctx.strokeStyle = `rgba(${SWORD_COLOR.gold},${alpha})`;
        ctx.lineWidth = 0.6;
        ctx.stroke();
      }
    }
  }
}

// 绘制底层阵法底纹 + 呼吸光晕
function drawFormationBG() {
  // 半透明拖影 流畅过渡
  ctx.fillStyle = 'rgba(5,5,8,0.18)';
  ctx.fillRect(0, 0, W, H);

  // 全局阵法光晕
  const centerX = W / 2;
  const centerY = H / 2;
  const bgGlow = ctx.createRadialGradient(centerX, centerY, H * 0.2, centerX, centerY, H * 0.9);
  bgGlow.addColorStop(0, 'rgba(255,215,0,0.04)');
  bgGlow.addColorStop(1, 'rgba(5,5,8,0)');
  ctx.fillStyle = bgGlow;
  ctx.fillRect(0, 0, W, H);
}

// 绘制手势区域剑罡光圈
function drawHandAura(points, mode) {
  const color = MODE_CONFIG[mode].color;
  for (const pt of points) {
    const aura = ctx.createRadialGradient(pt.x, pt.y, 0, pt.x, pt.y, 80);
    aura.addColorStop(0, `rgba(${color},0.18)`);
    aura.addColorStop(1, `rgba(${color},0)`);
    ctx.beginPath();
    ctx.arc(pt.x, pt.y, 80, 0, Math.PI * 2);
    ctx.fillStyle = aura;
    ctx.fill();
  }
}

// ===================== 手势识别逻辑（保留+优化） =====================
let handData = [];
let currentMode = 'attract';
const HAND_LINKS = [[0,1],[1,2],[2,3],[3,4],[0,5],[5,6],[6,7],[7,8],[5,9],[9,10],[10,11],[11,12],[9,13],[13,14],[14,15],[15,16],[13,17],[17,18],[18,19],[19,20],[0,17]];

// 识别手势 → 对应剑阵招式
function detectSwordMode(landmarks, handCount) {
  if (!landmarks || !landmarks.length) return 'attract';
  if (handCount >= 2) return 'vortex'; // 双手 = 轮转剑阵
  const lm = landmarks[0];
  const fingerState = [
    lm[8].y < lm[6].y,  // 食指
    lm[12].y < lm[10].y,// 中指
    lm[16].y < lm[14].y,// 无名指
    lm[20].y < lm[18].y // 小指
  ];
  const openFinger = fingerState.filter(Boolean).length;

  if (openFinger === 1 && fingerState[0]) return 'draw';    // 单指伸出 = 剑气穿刺
  if (openFinger <= 1 && !fingerState[0]) return 'repel';    // 握拳 = 凝剑聚罡
  return 'attract'; // 全张开 = 布开剑阵
}

// 手势坐标转屏幕坐标
function getHandScreenPoints(landmarks) {
  const points = [];
  const keyPoints = [0,4,8,12,16,20,9];
  for (const lm of landmarks) {
    for (const idx of keyPoints) {
      points.push({
        x: (1 - lm[idx].x) * W,
        y: lm[idx].y * H
      });
    }
  }
  return points;
}

// 绘制摄像头内手部关键点
function drawHandLandmarks() {
  if (!handData.length) { octx.clearRect(0,0,128,96); return; }
  octx.clearRect(0,0,128,96);
  const lm = handData[0];
  octx.strokeStyle = `rgba(${SWORD_COLOR.gold},0.6)`;
  octx.lineWidth = 1.2;

  // 绘制手骨连线
  for (const [a,b] of HAND_LINKS) {
    octx.beginPath();
    octx.moveTo(lm[a].x * 128, lm[a].y * 96);
    octx.lineTo(lm[b].x * 128, lm[b].y * 96);
    octx.stroke();
  }
  // 绘制指尖节点
  const tips = [4,8,12,16,20];
  for (let i = 0; i < lm.length; i++) {
    octx.beginPath();
    octx.arc(lm[i].x * 128, lm[i].y * 96, tips.includes(i) ? 4 : 2, 0, Math.PI * 2);
    octx.fillStyle = tips.includes(i) ? `rgba(${SWORD_COLOR.gold},0.95)` : 'rgba(255,255,255,0.7)';
    octx.fill();
  }
}

// ===================== 粒子初始化 & 主渲染循环 =====================
// 粒子数量：移动端700 / 桌面端1100 平衡画质与性能
const PARTICLE_COUNT = window.innerWidth < 768 ? 700 : 1100;
const swordParticles = Array.from({length: PARTICLE_COUNT}, () => new SwordParticle());

// 主渲染循环
function animateLoop() {
  requestAnimationFrame(animateLoop);
  frameN++;
  drawFormationBG();

  const handPoints = getHandScreenPoints(handData);
  const newMode = detectSwordMode(handData, handData.length);
  
  // 手势切换 → 触发对应音效【核心联动】
  if(newMode !== currentMode){
    currentMode = newMode;
    playModeAudio(currentMode);
  }

  // 更新所有剑粒子
  for (const sp of swordParticles) sp.update(handPoints, currentMode);

  // 绘制剑网 → 剑粒子 → 手部剑罡
  drawSwordNet(swordParticles);
  for (const sp of swordParticles) sp.draw();
  drawHandAura(handPoints, currentMode);
  drawHandLandmarks();

  // 刷新UI文字
  if (frameN % 12 === 0) {
    const cfg = MODE_CONFIG[currentMode];
    document.getElementById('modeBadge').textContent = `${cfg.emoji} ${cfg.name}`;
    document.getElementById('stStatus').textContent = handData.length > 0 ? '结印中' : '待机';
  }
}

// ===================== 加载 & 摄像头权限逻辑 =====================
function setLoadProgress(pct, msg) {
  document.getElementById('loadBar').style.width = pct + '%';
  document.getElementById('loadMsg').textContent = msg;
}

// 启动手势识别模型
function initMediaPipe(video) {
  const hands = new Hands({
    locateFile: file => `https://cdn.jsdelivr.net/npm/@mediapipe/hands/${file}`
  });
  // 高精度手势配置
  hands.setOptions({
    maxNumHands: 2,
    modelComplexity: 2,
    minDetectionConfidence: 0.7,
    minTrackingConfidence: 0.6
  });
  hands.onResults(res => {
    handData = res.multiHandLandmarks || [];
  });

  const camera = new Camera(video, {
    onFrame: async () => await hands.send({image: video}),
    width: 640, height: 480
  });

  camera.start()
    .then(() => {
      setLoadProgress(100, '剑阵启动成功 ✓');
      document.getElementById('stCount').textContent = PARTICLE_COUNT;
      setTimeout(() => {
        const loadScreen = document.getElementById('loadingScreen');
        loadScreen.style.opacity = '0';
        setTimeout(() => loadScreen.style.display = 'none', 900);
        startBGM(); // 加载完成后启动剑阵背景音
      }, 600);
    })
    .catch(err => {
      console.error(err);
      setLoadProgress(100, '启动失败，请刷新页面');
    });
}

// 请求摄像头权限
function requestCamera() {
  setLoadProgress(70, '请求摄像权限...');
  navigator.mediaDevices.getUserMedia({
    video: { width: {ideal:640}, height:{ideal:480}, facingMode:'user' }
  })
  .then(stream => {
    const video = document.getElementById('inputVideo');
    video.srcObject = stream;
    video.onloadedmetadata = () => {
      setLoadProgress(88, '载入剑阵识纹...');
      initMediaPipe(video);
    };
  })
  .catch(() => {
    document.getElementById('permScreen').style.display = 'flex';
    setLoadProgress(65, '等待权限授权');
  });
}

// 页面启动入口
function bootSystem() {
  setLoadProgress(10, '加载仙侠阵法模型...');
  animateLoop();

  const allowBtn = document.getElementById('allowBtn');
  allowBtn.onclick = () => {
    document.getElementById('permScreen').style.display = 'none';
    unlockAudio(); // 点击按钮解锁音频（规避浏览器限制）
    requestCamera();
  };

  // 等待MediaPipe模型加载
  let tryCount = 0;
  const loadCheck = setInterval(() => {
    tryCount++;
    const progress = 10 + Math.min(tryCount * 4, 55);
    setLoadProgress(progress, '加载阵法资源中...');

    if (typeof Hands !== 'undefined' && typeof Camera !== 'undefined') {
      clearInterval(loadCheck);
      setLoadProgress(65, '阵法初始化完成');
      requestCamera();
    }
    if (tryCount > 45) clearInterval(loadCheck);
  }, 300);
}

// 页面退出/隐藏时暂停音效
document.addEventListener('visibilitychange', () => {
  if(document.hidden) stopAllAudio();
  else if(audioUnlocked) startBGM();
});

window.addEventListener('load', bootSystem);
</script>
