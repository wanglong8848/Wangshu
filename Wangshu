<style>
  @import url('https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;700;900&display=swap');
  *{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
  html,body{width:100%;height:100%;overflow:hidden;background:#050508;font-family:'Noto Serif SC',serif;color:#fff}
  /* 主画布 剑阵主体 */
  #mainCanvas{position:fixed;top:0;left:0;width:100%;height:100%;z-index:1}
  /* 加载界面 国风样式 */
  #loadingScreen{position:fixed;inset:0;background:#050508;z-index:200;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:28px;transition:opacity 0.8s ease}
  .load-title{font-size:clamp(18px,5vw,36px);font-weight:900;letter-spacing:8px;text-align:center;line-height:1.8;
    background:linear-gradient(135deg,#FFD700,#36CFFB,#FF4A2C);
    -webkit-background-clip:text;-webkit-text-fill-color:transparent;
    text-shadow:0 0 20px rgba(255,215,0,0.3);
  }
  .load-bar-wrap{width:280px;height:3px;background:rgba(255,215,0,0.15);border-radius:3px;overflow:hidden}
  .load-bar{height:100%;background:linear-gradient(90deg,#FFD700,#36CFFB);width:0%;transition:width 0.4s;box-shadow:0 0 12px #FFD700}
