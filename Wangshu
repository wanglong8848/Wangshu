  /* 招式提示标签 */
  #modeBadge{position:fixed;bottom:calc(env(safe-area-inset-bottom,0px) + 20px);left:50%;transform:translateX(-50%);z-index:10;
    padding:10px 24px;background:rgba(0,0,0,0.7);border:1px solid rgba(255,215,0,0.3);border-radius:24px;
    font-size:12px;letter-spacing:4px;color:#FFD700;pointer-events:none;white-space:nowrap
  }
  /* 操作指引 */
  #guide{position:fixed;left:20px;bottom:calc(env(safe-area-inset-bottom,0px) + 80px);z-index:10;pointer-events:none}
  .g-item{display:flex;align-items:center;gap:10px;margin-bottom:8px}
  .g-icon{font-size:16px;width:22px;text-align:center;color:#36CFFB}
  .g-text{font-size:11px;letter-spacing:2px;color:rgba(255,255,255,0.45)}
  /* 屏幕扫描线 仙侠氛围 */
  body::after{content:'';position:fixed;inset:0;z-index:50;pointer-events:none;
    background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(255,215,0,0.02) 3px,rgba(255,215,0,0.02) 6px)
  }
</style>
